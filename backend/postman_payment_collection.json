          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token_admin}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/payments",
              "host": [
