        {
          "name": "Admin: Get Split Revenue",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token_admin}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/revenue",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "revenue"
              ]
            },
            "description": "Retrieves aggregated GTV (Gross Transaction Value), standard commissions (10%), platform operation fees (5%), and net provider distributions (85%)."
          }
        }
      ]
    }
