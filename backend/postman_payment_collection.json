{
  "info": {
    "_postman_id": "4b6c31bf-409b-44ec-b91c-7fc625d5d677",
    "name": "ServiceHub - Hyperlocal Service Marketplace Payment Module",
    "description": "Comprehensive Postman collection containing standard API endpoints for the Payment, Invoice, Refund, and Analytics engine. Built with standard variables and request payloads.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "User Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@example.com\",\n  \"password\": \"SecurePass123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Login endpoint to receive the JWT authorization token. Copy this token into the `jwt_token` environment variable."
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Razorpay Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": 1,\n  \"amount\": 1500.00\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/payments/create-order",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "payments",
                "create-order"
              ]
            },
            "description": "Initializes a Razorpay payment transaction. Returns a unique order ID."
          }
        },
        {
          "name": "Verify Payment Signature",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": 1,\n  \"razorpayOrderId\": \"order_sim_12345\",\n  \"razorpayPaymentId\": \"pay_sim_abcde\",\n  \"razorpaySignature\": \"sig_sim_67890\",\n  \"paymentMethod\": \"UPI\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/payments/verify",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "payments",
                "verify"
              ]
            },
            "description": "Submits signature and payment details to verify the transaction. On success, transitions booking to ACCEPTED and generates invoice."
          }
        },
        {
          "name": "Get User Payment History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/payments/history",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "payments",
                "history"
              ]
            },
            "description": "Returns a history of all payments made or received by the logged-in customer or provider."
          }
        },
        {
          "name": "Get Payment details by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/payments/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "payments",
                "1"
              ]
            }
          }
        },
        {
          "name": "Check Status by Booking ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/payments/status/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "payments",
                "status",
                "1"
              ]
            }
          }
        }
      ]
    },
