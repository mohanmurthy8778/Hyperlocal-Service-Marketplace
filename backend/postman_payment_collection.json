          "name": "Get Invoice Metadata",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/invoices/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "invoices",
                "1"
              ]
            }
          }
        },
        {
          "name": "Download Invoice PDF",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/invoices/download/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "invoices",
                "download",
                "1"
              ]
            },
            "description": "Streams a binary download of the professional PDF invoice containing brand headers, transaction breakdown, and tax summaries."
          }
        }
      ]
    },
    {
      "name": "Refunds",
      "item": [
        {
          "name": "Request Refund",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentId\": 1,\n  \"reason\": \"Service provider did not show up\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/payments/refund/request",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "payments",
                "refund",
                "request"
              ]
            }
          }
        },
        {
          "name": "Admin: Approve Refund",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token_admin}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/payments/refund/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "payments",
                "refund",
                "1"
              ]
            },
            "description": "Admin approval endpoint. Processes the refund through Razorpay (with mock fallback) and cancels the Booking state."
          }
        },
        {
          "name": "Admin: Reject Refund",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token_admin}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/payments/refund/1/reject",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "payments",
                "refund",
                "1",
                "reject"
              ]
            }
          }
        },
        {
          "name": "Admin: Get All Refunds",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token_admin}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/payments/refunds",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "payments",
                "refunds"
              ]
            }
          }
        }
      ]
    },
